{"screenId":"8e68fd6a9db245579604ef70f6bcce38","projectId":"5555131273081994847","htmlContent":"<!DOCTYPE html>\n\n<html class=\"dark\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0, viewport-fit=cover\" name=\"viewport\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Manrope:wght@300;400;500;600;700;800&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    colors: {\n                        \"outline\": \"#76757a\",\n                        \"primary-fixed\": \"#00f5f5\",\n                        \"surface-dim\": \"#0e0e12\",\n                        \"tertiary-fixed\": \"#bda1ff\",\n                        \"surface-variant\": \"#25252b\",\n                        \"tertiary-container\": \"#7000ff\",\n                        \"surface-container-highest\": \"#25252b\",\n                        \"secondary-fixed-dim\": \"#ffa6f3\",\n                        \"surface-bright\": \"#2c2b32\",\n                        \"error-container\": \"#9f0519\",\n                        \"secondary-fixed\": \"#ffbdf3\",\n                        \"on-surface\": \"#f3eff6\",\n                        \"on-primary-container\": \"#005d5d\",\n                        \"primary\": \"#c1fffe\",\n                        \"on-tertiary-container\": \"#f8f1ff\",\n                        \"tertiary\": \"#ac89ff\",\n                        \"primary-dim\": \"#00e6e6\",\n                        \"on-secondary\": \"#400040\",\n                        \"on-tertiary-fixed\": \"#1f0052\",\n                        \"surface-tint\": \"#c1fffe\",\n                        \"primary-fixed-dim\": \"#00e6e6\",\n                        \"on-secondary-container\": \"#fff5f9\",\n                        \"on-primary-fixed-variant\": \"#006262\",\n                        \"background\": \"#0e0e12\",\n                        \"secondary-dim\": \"#ff51fa\",\n                        \"tertiary-fixed-dim\": \"#b190ff\",\n                        \"error-dim\": \"#d7383b\",\n                        \"surface-container-lowest\": \"#000000\",\n                        \"on-tertiary\": \"#290067\",\n                        \"surface-container-low\": \"#131318\",\n                        \"on-primary\": \"#006767\",\n                        \"on-primary-fixed\": \"#004343\",\n                        \"inverse-on-surface\": \"#55545a\",\n                        \"inverse-surface\": \"#fcf8fe\",\n                        \"on-background\": \"#f3eff6\",\n                        \"secondary-container\": \"#a900a9\",\n                        \"on-error\": \"#490006\",\n                        \"tertiary-dim\": \"#874cff\",\n                        \"on-error-container\": \"#ffa8a3\",\n                        \"outline-variant\": \"#48474c\",\n                        \"inverse-primary\": \"#006a6a\",\n                        \"on-surface-variant\": \"#acaab0\",\n                        \"secondary\": \"#ff51fa\",\n                        \"primary-container\": \"#00ffff\",\n                        \"surface-container-high\": \"#1f1f25\",\n                        \"on-secondary-fixed\": \"#620061\",\n                        \"on-tertiary-fixed-variant\": \"#4700a7\",\n                        \"error\": \"#ff716c\",\n                        \"surface\": \"#0e0e12\",\n                        \"surface-container\": \"#19191e\",\n                        \"on-secondary-fixed-variant\": \"#920091\"\n                    },\n                    fontFamily: {\n                        \"headline\": [\"Space Grotesk\"],\n                        \"body\": [\"Manrope\"],\n                        \"label\": [\"Space Grotesk\"]\n                    },\n                    borderRadius: {\"DEFAULT\": \"0.125rem\", \"lg\": \"0.25rem\", \"xl\": \"0.5rem\", \"full\": \"0.75rem\"},\n                },\n            },\n        }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        .glow-primary {\n            box-shadow: 0 0 20px rgba(0, 255, 255, 0.3), 0 0 40px rgba(0, 255, 255, 0.1);\n        }\n        .glow-secondary {\n            box-shadow: 0 0 15px rgba(255, 81, 250, 0.4);\n        }\n        .glass-panel {\n            background: rgba(25, 25, 30, 0.6);\n            backdrop-filter: blur(20px);\n        }\n        body {\n            background-color: #0e0e12;\n            overflow: hidden;\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"font-body text-on-surface antialiased select-none\">\n<!-- Top Navigation Shell -->\n<header class=\"fixed top-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-[#0e0e12] dark:bg-[#0e0e12]\">\n<div class=\"flex items-center gap-2\">\n<span class=\"text-xl font-headline font-bold tracking-[0.2em] text-[#00FFFF]\">KINETIC</span>\n</div>\n<div class=\"flex items-center gap-4\">\n<div class=\"flex flex-col items-end mr-4\">\n<span class=\"text-[10px] font-headline tracking-[0.15em] text-on-surface-variant uppercase\">Best System Score</span>\n<span class=\"text-xl font-headline font-bold text-[#00FFFF] tracking-tighter\">1,240,490</span>\n</div>\n<button class=\"active:scale-95 transition-transform duration-200 text-[#f3eff6]/60 hover:text-[#ff51fa] transition-colors duration-300\">\n<span class=\"material-symbols-outlined text-2xl\" data-icon=\"settings\">settings</span>\n</button>\n</div>\n</header>\n<!-- Visual Background Atmosphere -->\n<div class=\"fixed inset-0 pointer-events-none overflow-hidden\">\n<div class=\"absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-primary/5 blur-[120px]\"></div>\n<div class=\"absolute bottom-[-5%] right-[-5%] w-[30%] h-[30%] rounded-full bg-secondary/5 blur-[100px]\"></div>\n<div class=\"absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(25,25,30,0)_0%,rgba(14,14,18,1)_100%)]\"></div>\n<!-- Decorative grid/lines for \"Cyber-Editorial\" look -->\n<div class=\"absolute inset-0 opacity-[0.03]\" style=\"background-image: linear-gradient(#f3eff6 1px, transparent 1px), linear-gradient(90deg, #f3eff6 1px, transparent 1px); background-size: 80px 80px;\"></div>\n</div>\n<!-- Main Content Canvas -->\n<main class=\"relative h-screen flex flex-col items-center justify-center px-8\">\n<!-- Asymmetric Decorative Text -->\n<div class=\"absolute top-[25%] left-8 md:left-24 max-w-xs\">\n<h2 class=\"font-headline text-xs tracking-[0.3em] text-secondary uppercase mb-2\">Protocol Active</h2>\n<p class=\"font-body text-sm text-on-surface-variant leading-relaxed font-light\">\n                Neural link established. System status: Optimal. Awaiting pilot authentication for sector 04 entry.\n            </p>\n</div>\n<!-- Center Hero / Play Interaction -->\n<div class=\"relative group\">\n<!-- Pulsing Ambient Background -->\n<div class=\"absolute -inset-16 bg-primary/10 rounded-full blur-3xl opacity-50 group-hover:bg-primary/20 transition-all duration-700\"></div>\n<!-- Play Button Container -->\n<button class=\"relative flex flex-col items-center justify-center w-56 h-56 rounded-full border border-primary/20 glass-panel glow-primary active:scale-90 cubic-bezier(0.22,1,0.36,1) transition-all duration-300 group\">\n<div class=\"absolute inset-2 rounded-full border border-primary/5\"></div>\n<span class=\"font-headline font-black text-6xl tracking-[0.1em] text-transparent bg-clip-text bg-gradient-to-br from-primary to-primary-container group-hover:tracking-[0.2em] transition-all duration-500\">PLAY</span>\n<div class=\"mt-2 flex items-center gap-2\">\n<span class=\"w-1.5 h-1.5 rounded-full bg-secondary glow-secondary\"></span>\n<span class=\"text-[10px] font-headline tracking-[0.2em] text-on-surface/40 uppercase\">Ready</span>\n</div>\n</button>\n</div>\n<!-- Secondary Information / Meta Data -->\n<div class=\"absolute bottom-32 right-8 md:right-24 flex flex-col items-end gap-1\">\n<span class=\"font-headline text-[10px] tracking-widest text-on-surface-variant uppercase\">Active Event</span>\n<div class=\"flex items-center gap-3 glass-panel px-4 py-2 rounded-sm border-r-2 border-secondary\">\n<span class=\"font-body font-bold text-sm tracking-tight\">NEON SURGE WEEKEND</span>\n<span class=\"font-headline text-secondary text-xs font-bold\">+20% XP</span>\n</div>\n</div>\n<!-- Bottom Stat Cards (Bento-lite) -->\n<div class=\"absolute bottom-10 left-1/2 -translate-x-1/2 flex gap-4 w-full max-w-lg px-6\">\n<div class=\"flex-1 bg-surface-container-low/40 backdrop-blur-md p-4 rounded-sm border-t border-primary/10\">\n<p class=\"text-[9px] font-headline tracking-widest text-on-surface-variant uppercase mb-1\">Rank</p>\n<p class=\"text-lg font-headline font-bold text-on-surface\">VANGUARD II</p>\n</div>\n<div class=\"flex-1 bg-surface-container-low/40 backdrop-blur-md p-4 rounded-sm border-t border-secondary/10\">\n<p class=\"text-[9px] font-headline tracking-widest text-on-surface-variant uppercase mb-1\">Credits</p>\n<p class=\"text-lg font-headline font-bold text-secondary\">42,850</p>\n</div>\n</div>\n</main>\n<!-- Bottom Navigation Shell -->\n<nav class=\"fixed bottom-0 w-full z-50 flex justify-around items-center px-4 pb-safe h-20 bg-[#19191e]/80 backdrop-blur-xl shadow-[0_-4px_24px_rgba(0,0,0,0.4)]\">\n<button class=\"flex flex-col items-center justify-center text-[#00FFFF] border-t-2 border-[#00FFFF] pt-2 active:scale-90 cubic-bezier(0.22,1,0.36,1) transition-all\">\n<span class=\"material-symbols-outlined text-2xl\" data-icon=\"grid_view\" style=\"font-variation-settings: 'FILL' 1;\">grid_view</span>\n<span class=\"font-['Manrope'] text-[10px] font-bold tracking-widest uppercase\">HOME</span>\n</button>\n<button class=\"flex flex-col items-center justify-center text-[#f3eff6]/40 pt-2 hover:text-[#ff51fa] active:scale-90 cubic-bezier(0.22,1,0.36,1) transition-all\">\n<span class=\"material-symbols-outlined text-2xl\" data-icon=\"shopping_bag\">shopping_bag</span>\n<span class=\"font-['Manrope'] text-[10px] font-bold tracking-widest uppercase\">VAULT</span>\n</button>\n<button class=\"flex flex-col items-center justify-center text-[#f3eff6]/40 pt-2 hover:text-[#ff51fa] active:scale-90 cubic-bezier(0.22,1,0.36,1) transition-all\">\n<span class=\"material-symbols-outlined text-2xl\" data-icon=\"leaderboard\">leaderboard</span>\n<span class=\"font-['Manrope'] text-[10px] font-bold tracking-widest uppercase\">RANK</span>\n</button>\n<button class=\"flex flex-col items-center justify-center text-[#f3eff6]/40 pt-2 hover:text-[#ff51fa] active:scale-90 cubic-bezier(0.22,1,0.36,1) transition-all\">\n<span class=\"material-symbols-outlined text-2xl\" data-icon=\"person\">person</span>\n<span class=\"font-['Manrope'] text-[10px] font-bold tracking-widest uppercase\">PILOT</span>\n</button>\n</nav>\n<!-- Aesthetic Decorative Corner elements -->\n<div class=\"fixed top-20 left-6 flex flex-col gap-1 opacity-20\">\n<div class=\"w-8 h-0.5 bg-primary\"></div>\n<div class=\"w-4 h-0.5 bg-primary\"></div>\n</div>\n<div class=\"fixed bottom-24 right-6 flex flex-col gap-1 items-end opacity-20\">\n<div class=\"w-12 h-0.5 bg-secondary\"></div>\n<div class=\"w-6 h-0.5 bg-secondary\"></div>\n</div>\n</body></html>"}
