{"screenId":"bf0de3eac3d94d279a1e92809f93b240","projectId":"5555131273081994847","htmlContent":"<!DOCTYPE html>\n\n<html class=\"dark\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Kinetic Luminescence - Gameplay HUD</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Manrope:wght@300;400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    colors: {\n                        \"tertiary-fixed\": \"#bda1ff\",\n                        \"surface-container-highest\": \"#25252b\",\n                        \"on-secondary-fixed-variant\": \"#920091\",\n                        \"secondary\": \"#ff51fa\",\n                        \"surface-container-high\": \"#1f1f25\",\n                        \"inverse-primary\": \"#006a6a\",\n                        \"secondary-dim\": \"#ff51fa\",\n                        \"on-primary\": \"#006767\",\n                        \"on-tertiary\": \"#290067\",\n                        \"on-primary-fixed-variant\": \"#006262\",\n                        \"error-container\": \"#9f0519\",\n                        \"tertiary-dim\": \"#874cff\",\n                        \"tertiary-fixed-dim\": \"#b190ff\",\n                        \"secondary-container\": \"#a900a9\",\n                        \"primary\": \"#c1fffe\",\n                        \"on-tertiary-container\": \"#f8f1ff\",\n                        \"on-error\": \"#490006\",\n                        \"surface-container-lowest\": \"#000000\",\n                        \"inverse-surface\": \"#fcf8fe\",\n                        \"primary-fixed-dim\": \"#00e6e6\",\n                        \"secondary-fixed\": \"#ffbdf3\",\n                        \"primary-dim\": \"#00e6e6\",\n                        \"on-tertiary-fixed-variant\": \"#4700a7\",\n                        \"on-secondary\": \"#400040\",\n                        \"surface-tint\": \"#c1fffe\",\n                        \"on-background\": \"#f3eff6\",\n                        \"primary-fixed\": \"#00f5f5\",\n                        \"on-surface\": \"#f3eff6\",\n                        \"secondary-fixed-dim\": \"#ffa6f3\",\n                        \"surface-variant\": \"#25252b\",\n                        \"error\": \"#ff716c\",\n                        \"surface\": \"#0e0e12\",\n                        \"primary-container\": \"#00ffff\",\n                        \"on-surface-variant\": \"#acaab0\",\n                        \"outline-variant\": \"#48474c\",\n                        \"surface-container\": \"#19191e\",\n                        \"outline\": \"#76757a\",\n                        \"on-secondary-container\": \"#fff5f9\",\n                        \"surface-bright\": \"#2c2b32\",\n                        \"inverse-on-surface\": \"#55545a\",\n                        \"on-tertiary-fixed\": \"#1f0052\",\n                        \"on-secondary-fixed\": \"#620061\",\n                        \"background\": \"#0e0e12\",\n                        \"on-primary-fixed\": \"#004343\",\n                        \"on-primary-container\": \"#005d5d\",\n                        \"surface-container-low\": \"#131318\",\n                        \"error-dim\": \"#d7383b\",\n                        \"on-error-container\": \"#ffa8a3\",\n                        \"tertiary-container\": \"#7000ff\",\n                        \"surface-dim\": \"#0e0e12\",\n                        \"tertiary\": \"#ac89ff\"\n                    },\n                    fontFamily: {\n                        \"headline\": [\"Space Grotesk\"],\n                        \"body\": [\"Manrope\"],\n                        \"label\": [\"Space Grotesk\"]\n                    },\n                    borderRadius: {\"DEFAULT\": \"0.125rem\", \"lg\": \"0.25rem\", \"xl\": \"0.5rem\", \"full\": \"0.75rem\"},\n                },\n            },\n        }\n    </script>\n<style>\n        body {\n            background-color: #0e0e12;\n            color: #f3eff6;\n            font-family: 'Manrope', sans-serif;\n            overflow: hidden;\n        }\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        .glass-panel {\n            backdrop-filter: blur(24px);\n            background: rgba(25, 25, 30, 0.4);\n        }\n        .hud-scanline {\n            background: linear-gradient(to bottom, transparent 50%, rgba(0, 255, 255, 0.02) 50%);\n            background-size: 100% 4px;\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"relative min-h-screen bg-surface\">\n<!-- Active Game Area Background (Conceptual) -->\n<div class=\"absolute inset-0 z-0 overflow-hidden pointer-events-none\">\n<div class=\"hud-scanline absolute inset-0 opacity-20\"></div>\n<div class=\"absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(0,255,255,0.05)_0%,transparent_70%)]\"></div>\n<img class=\"w-full h-full object-cover opacity-30 grayscale contrast-125\" data-alt=\"abstract cybernetic landscape with glowing grid lines and deep blue geometric structures in a dark void\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuCHO-4rnEJl8YulfXXBDE0tdjRy1NOCCXeNrRwmwWcJDuVlnGxBpfjvCDk_RZ7JdWxfoZqAnXmgQfa09vOcALOhmiAqcfHlq4926IVKkfdU88P6u1or10K5GmnvpxFB90G3qbnHwXGCdOYBIgPYWzVch-NLdHUS1FXyU-V-9fulF-aoG3dqjxQXHOKx3ZHgwVHDR4Cd0YU3t7MA0SVpDm0iYikg0oP3qO6Jm-202w181T3eGz8YYjVrl806j7_ImCbqRRUmDnSeAI8\"/>\n</div>\n<!-- TopAppBar - Predicted Component -->\n<header class=\"fixed top-0 left-0 w-full z-50 flex justify-between items-center bg-gradient-to-b from-black/40 to-transparent backdrop-blur-md pt-4 px-6 h-20\">\n<div class=\"flex items-center gap-4\">\n<div class=\"flex flex-col\">\n<span class=\"text-slate-400 font-headline tracking-widest uppercase text-[10px] font-bold\">LEVEL 12</span>\n<div class=\"flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-cyan-400\" data-icon=\"sports_esports\">sports_esports</span>\n<h1 class=\"text-cyan-400 dark:text-cyan-300 font-headline tracking-widest uppercase text-sm font-bold\">SCORE 450</h1>\n</div>\n</div>\n</div>\n<button class=\"active:scale-95 duration-200 cubic-bezier(0.22,1,0.36,1) hover:opacity-80 transition-opacity p-2 rounded-lg bg-surface-container/50 border border-outline-variant/15\">\n<span class=\"material-symbols-outlined text-cyan-400\" data-icon=\"pause\">pause</span>\n</button>\n</header>\n<!-- Bottom HUD Components -->\n<div class=\"fixed bottom-0 left-0 w-full p-8 z-50 flex justify-between items-end\">\n<!-- LIVES Indicator (Bottom Left) -->\n<div class=\"flex flex-col gap-2\">\n<span class=\"font-headline text-[10px] tracking-[0.2em] text-on-surface-variant font-bold uppercase\">LIVES</span>\n<div class=\"flex gap-2\">\n<div class=\"w-8 h-8 flex items-center justify-center glass-panel border border-primary/20 shadow-[0_0_15px_rgba(0,255,255,0.1)]\">\n<span class=\"material-symbols-outlined text-primary text-lg\" data-icon=\"favorite\" style=\"font-variation-settings: 'FILL' 1;\">favorite</span>\n</div>\n<div class=\"w-8 h-8 flex items-center justify-center glass-panel border border-primary/20 shadow-[0_0_15px_rgba(0,255,255,0.1)]\">\n<span class=\"material-symbols-outlined text-primary text-lg\" data-icon=\"favorite\" style=\"font-variation-settings: 'FILL' 1;\">favorite</span>\n</div>\n<div class=\"w-8 h-8 flex items-center justify-center glass-panel border border-primary/20 shadow-[0_0_15px_rgba(0,255,255,0.1)]\">\n<span class=\"material-symbols-outlined text-primary text-lg\" data-icon=\"favorite\" style=\"font-variation-settings: 'FILL' 1;\">favorite</span>\n</div>\n</div>\n</div>\n<!-- BOOST Meter (Bottom Right) -->\n<div class=\"flex flex-col items-end gap-2\">\n<div class=\"flex items-center gap-2\">\n<span class=\"font-headline text-[10px] tracking-[0.2em] text-on-surface-variant font-bold uppercase\">BOOST READY</span>\n<div class=\"w-1.5 h-1.5 rounded-full bg-secondary shadow-[0_0_8px_#ff51fa] animate-pulse\"></div>\n</div>\n<div class=\"relative w-48 h-3 bg-surface-container overflow-hidden\">\n<!-- Boost fill gradient -->\n<div class=\"absolute inset-y-0 left-0 bg-gradient-to-r from-primary to-primary-container shadow-[0_0_15px_rgba(0,255,255,0.4)]\" style=\"width: 85%;\"></div>\n<!-- Measurement markers -->\n<div class=\"absolute inset-0 flex justify-between px-1\">\n<div class=\"w-[1px] h-full bg-surface/40\"></div>\n<div class=\"w-[1px] h-full bg-surface/40\"></div>\n<div class=\"w-[1px] h-full bg-surface/40\"></div>\n<div class=\"w-[1px] h-full bg-surface/40\"></div>\n</div>\n</div>\n<div class=\"flex gap-4 mt-1\">\n<span class=\"font-headline text-[10px] text-on-surface-variant\">00</span>\n<span class=\"font-headline text-[10px] text-primary font-bold\">85%</span>\n</div>\n</div>\n</div>\n<!-- Active Central \"Reticle\" UI (Aesthetic Garnish) -->\n<div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none opacity-40\">\n<div class=\"relative w-64 h-64 border border-outline-variant/10 rounded-full flex items-center justify-center\">\n<!-- Subtle HUD accents -->\n<div class=\"absolute top-0 left-1/2 -translate-x-1/2 w-4 h-[1px] bg-primary\"></div>\n<div class=\"absolute bottom-0 left-1/2 -translate-x-1/2 w-4 h-[1px] bg-primary\"></div>\n<div class=\"absolute left-0 top-1/2 -translate-y-1/2 h-4 w-[1px] bg-primary\"></div>\n<div class=\"absolute right-0 top-1/2 -translate-y-1/2 h-4 w-[1px] bg-primary\"></div>\n<!-- Small interior indicators -->\n<div class=\"w-32 h-32 border border-primary/5 rounded-full flex items-center justify-center italic font-headline text-[8px] tracking-widest text-primary/30\">\n                SYNC_READY\n            </div>\n</div>\n</div>\n<!-- Screen Edge Vignette -->\n<div class=\"fixed inset-0 pointer-events-none shadow-[inset_0_0_150px_rgba(0,0,0,0.8)] z-40\"></div>\n</body></html>"}
